# Public deployment URLs only — safe to commit. Use this when setting Render / Vercel env vars.
# Database, JWT, and Cloudinary stay in each platform’s secret store only (not here).

# --- Backend (Render Web Service) ---
RENDER_API_BASE_URL=https://chat-app-o2uw.onrender.com

# --- Frontend (Vercel) — set after your first deploy (no trailing slash) ---
VERCEL_APP_URL=

# --- Sync checklist (copy into dashboards; update this file when URLs change) ---
#
# Render → Environment:
#   CLIENT_URL = <VERCEL_APP_URL> when front is live, or http://localhost:5173 while testing UI locally
#   ALLOWED_ORIGINS = <VERCEL_APP_URL>,http://localhost:5173,http://127.0.0.1:5173
#
# Vercel → Project → Environment Variables (Production / Preview as needed):
#   VITE_API_URL = <RENDER_API_BASE_URL>
#   VITE_SOCKET_URL = <RENDER_API_BASE_URL>
#
# Local client/.env (point UI at deployed API while developing):
#   VITE_API_URL = <RENDER_API_BASE_URL>
#   VITE_SOCKET_URL = <RENDER_API_BASE_URL>
